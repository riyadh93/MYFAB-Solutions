{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myfab-solutions",
  "compatibility_date": "2026-05-06",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "myfab-solutions"
    }
  ]
}
